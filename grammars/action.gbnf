root ::= "{" ws "\"thought_process\"" ws ":" ws string "," ws "\"action\"" ws ":" ws actionval "," ws "\"target\"" ws ":" ws string "," ws "\"perceived_importance\"" ws ":" ws number "," ws "\"action_summary\"" ws ":" ws string "}"

ws ::= [ \t\n]*
string ::= "\"" ([^"\\\x7F\x00-\x1F] | "\\" (["\\/bfnrt] | "u" [0-9a-fA-F]{4}))* "\"" ws
actionval ::= ("\"EAT\"" | "\"MOVE_TO\"" | "\"GIVE\"" | "\"SPEAK\"" | "\"WAIT\"") ws
number ::= ("-"? [0-9] [0-9]? [0-9]?) ws
